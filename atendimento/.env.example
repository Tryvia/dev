# =====================================
# CONFIGURAÇÕES DE AMBIENTE - EXEMPLO
# Dashboard Tryvia BI v2.0
# =====================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA COM SUAS CREDENCIAIS

# =====================================
# SUPABASE
# =====================================
SUPABASE_URL=sua_url_aqui
SUPABASE_ANON_KEY=sua_anon_key_aqui

# =====================================
# GEMINI (Google AI)
# Obtenha em: https://aistudio.google.com/app/apikey
# =====================================
GEMINI_API_KEY=sua_gemini_key_aqui
GEMINI_MODEL=gemini-1.5-flash

# =====================================
# GROQ
# Obtenha em: https://console.groq.com/keys
# =====================================
GROQ_API_KEY=sua_groq_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# =====================================
# OPENROUTER
# Obtenha em: https://openrouter.ai/keys
# =====================================
OPENROUTER_API_KEY=sua_openrouter_key_aqui
OPENROUTER_MODEL=google/gemini-flash-1.5

# =====================================
# FRESHDESK
# =====================================
FRESHDESK_TICKET_URL=https://seudominio.freshdesk.com/a/tickets

# =====================================
# BOT WHATSAPP
# =====================================
BOT_PORT=3001
BOT_MAX_RETRIES=3
BOT_RETRY_DELAY_MS=5000
